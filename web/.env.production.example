# Production env for /web. Copy to web/.env on the server.

# Public site origin
WEB_SITE_URL=https://example.com

# Strapi origin (used at build time only)
CMS_BASE_URL=https://cms-9f3a2b.example.com

# Read-only API token. Generate in Strapi admin:
#   Settings -> API Tokens -> Create new
#     Name: web-read
#     Type: Read-only
#     Duration: Unlimited
# Paste the access key here.
CMS_READ_TOKEN=

# Force strapi mode (default: auto-detect from CMS_READ_TOKEN)
# CMS_MODE=strapi

# Shared secret for the revalidate webhook.
# Must match the value in cms/.env (REVALIDATE_SECRET).
REVALIDATE_SECRET=

# === On-demand revalidation (optional) ===
# When content changes in Strapi, the webhook fans out to one of these:
# NETLIFY_HOOK_URL=https://api.netlify.com/build_hooks/xxxx
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/xxxx
# CF_PURGE_URL=https://api.cloudflare.com/client/v4/zones/.../purge_cache
