---
import { getAllClientDownloads } from '@lib/cms';

const downloads = await getAllClientDownloads();

const iconFor = (platform) => {
  const map = {
    Windows: '<path d="M3 4l8-1.2v8.4H3V4zm9-1.4L21 1v10.2H12V2.6zM3 12.8h8V21l-8-1.2v-7zm9 0h9V23l-9-1.6V12.8z"/>',
    macOS: '<path d="M16.4 12.7c0-2.4 2-3.5 2.1-3.6-1.1-1.6-2.9-1.8-3.5-1.8-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.3 1.2 9.7.8 1.2 1.7 2.5 3 2.4 1.2 0 1.6-.8 3.1-.8s1.9.8 3.1.8 2.1-1.2 2.9-2.4c.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.3-1-2.3-4zM14 5.3c.6-.8 1.1-1.9 1-3-.9 0-2.1.6-2.7 1.4-.6.7-1.2 1.9-1 2.9 1 .1 2.1-.5 2.7-1.3z"/>',
    iOS: '<path d="M17.4 12.4c0-2.6 2.1-3.8 2.2-3.9-1.2-1.7-3-1.9-3.7-2-1.6-.2-3.1.9-3.9.9-.8 0-2-.9-3.4-.9-1.7 0-3.3 1-4.2 2.6-1.8 3.1-.5 7.7 1.3 10.2.9 1.2 1.8 2.6 3.2 2.5 1.3 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.5.9-1.4 1.3-2.7 1.4-2.8 0 0-2.4-1-2.4-4.1zM14.5 5c.7-.8 1.2-2 1-3.1-1 0-2.2.6-2.9 1.4-.6.7-1.2 1.9-1 3 1.1.1 2.2-.5 2.9-1.3z"/>',
    Android: '<path d="M5 9h14v9a1 1 0 01-1 1h-1v4h-2v-4H9v4H7v-4H6a1 1 0 01-1-1V9zm-2-2h18a1 1 0 011 1v1H2V8a1 1 0 011-1zm3.5-3l-1-1.7M17.5 4l1-1.7M9 4.5h6"/>',
    Linux: '<path d="M12 2c-2 0-3 1.5-3 3.5 0 1 .3 2 .8 2.7-1 1-2.8 3-2.8 5.5 0 1 .3 1.8.8 2.4-.5.8-.8 1.7-.8 2.6 0 .8.7 1.3 1.5 1.3.4 0 .8-.1 1.1-.4.4 1 1.3 1.4 2.4 1.4s2-.4 2.4-1.4c.3.3.7.4 1.1.4.8 0 1.5-.5 1.5-1.3 0-.9-.3-1.8-.8-2.6.5-.6.8-1.4.8-2.4 0-2.5-1.8-4.5-2.8-5.5.5-.7.8-1.7.8-2.7C15 3.5 14 2 12 2z"/>',
  };
  return map[platform] || '';
};
---
<div class="card p-5 sm:p-6">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neon-green/90">下载客户端</p>
      <h3 class="mt-1 text-lg font-semibold text-white">全平台覆盖，一键安装</h3>
    </div>
    <span class="chip !text-[10px]">v2.4.1</span>
  </div>

  {downloads.length === 0 ? (
    <p class="mt-6 text-sm text-slate-400">暂未配置客户端下载，请联系管理员。</p>
  ) : (
    <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {downloads.map((d) => {
        const href = d.storeUrl || d.downloadUrl || '#';
        const isExternal = !!(d.storeUrl || d.downloadUrl);
        return (
          <li class:list={['rounded-lg border border-white/5 bg-ink-900/50 p-4', d.highlight && 'ring-1 ring-neon-green/40']}>
            <div class="flex items-start gap-3">
              <span class="inline-flex size-9 items-center justify-center rounded-md bg-neon-green/10 text-neon-green shrink-0">
                <svg viewBox="0 0 24 24" class="size-5" fill="currentColor" set:html={iconFor(d.platform)} />
              </span>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-white">{d.label}</p>
                <p class="mt-0.5 text-[11px] text-slate-500">
                  {d.version}{d.fileSize && ` · ${d.fileSize}`}
                </p>
              </div>
            </div>
            {d.instructions && (
              <p class="mt-2.5 text-[11px] text-slate-500 leading-relaxed line-clamp-2">{d.instructions}</p>
            )}
            <a
              href={href}
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener' : undefined}
              class:list={[
                'mt-3 w-full',
                d.highlight ? 'btn-primary' : 'btn-ghost',
              ]}
            >
              {d.storeUrl ? '前往 App Store' : d.downloadUrl ? '立即下载' : '敬请期待'}
            </a>
          </li>
        );
      })}
    </ul>
  )}
</div>
