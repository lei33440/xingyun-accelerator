---
const { eyebrow, title, lede, class: className = '' } = Astro.props;
---
<div class:list={['max-w-2xl', className]}>
  {eyebrow && (
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-neon-green/90">
      {eyebrow}
    </p>
  )}
  {title && <h2 class="h-section mb-3">{title}</h2>}
  {lede && <p class="lede">{lede}</p>}
</div>
