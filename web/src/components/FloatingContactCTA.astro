---
import { getGlobalSettings } from '@lib/cms';
const settings = await getGlobalSettings();
const tg = settings.telegramLink || '#';
const wa = settings.whatsappNumber
  ? `https://wa.me/${String(settings.whatsappNumber).replace(/[^\d]/g, '')}`
  : null;
---
<div
  id="floating-cta"
  class="fixed bottom-5 right-5 z-50 max-w-xs rounded-2xl border border-neon-green/30 bg-ink-900/85 p-4 shadow-glow backdrop-blur-md"
>
  <div class="flex items-start gap-3">
    <span class="mt-0.5 inline-block size-2.5 rounded-full bg-neon-green animate-pulseDot"></span>
    <div class="flex-1">
      <p class="text-sm font-semibold text-white">需要测试流量或定制方案？</p>
      <p class="mt-0.5 text-xs text-slate-400">通常 5 分钟内人工回复。</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <a class="btn-primary !py-1.5 !text-xs" href={tg} target="_blank" rel="noopener">Telegram</a>
        {wa && <a class="btn-ghost !py-1.5 !text-xs" href={wa} target="_blank" rel="noopener">WhatsApp</a>}
        {settings.wechatId && <span class="chip">微信：{settings.wechatId}</span>}
      </div>
    </div>
    <button
      type="button"
      aria-label="Dismiss"
      onclick="document.getElementById('floating-cta')?.remove()"
      class="text-slate-500 hover:text-slate-300"
    >×</button>
  </div>
</div>
