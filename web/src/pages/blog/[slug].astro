---
import Base from '@layouts/Base.astro';
import RichText from '@components/RichText.astro';
import FloatingContactCTA from '@components/FloatingContactCTA.astro';
import { getAllArticles, getArticleBySlug, getGlobalSettings } from '@lib/cms';
import { formatDate } from '@lib/format';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return (articles || []).map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const [settings, article] = await Promise.all([getGlobalSettings(), getArticleBySlug(slug)]);

if (!article) {
  return Astro.redirect('/blog');
}

const seoTitle = article.seoTitle || article.title;
const seoDescription = article.seoDescription || article.excerpt || '';
const blocks = article.content || [];
---
<Base
  settings={settings}
  title={seoTitle}
  description={seoDescription}
  ogImage={article.coverImage?.url}
>
  <article class="container-x max-w-3xl pt-12 pb-16">
    <a href="/blog" class="text-xs text-slate-400 hover:text-white">← Back to blog</a>
    <header class="mt-4">
      <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
        {article.category && <span class="chip">{article.category}</span>}
        <span>{formatDate(article.publishedAt || article.createdAt)}</span>
        <span>·</span>
        <span>{article.readingMinutes || 5} min read</span>
      </div>
      <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-white">{article.title}</h1>
      {article.excerpt && <p class="lede mt-3">{article.excerpt}</p>}
    </header>

    {article.coverImage?.url && (
      <img
        src={article.coverImage.url}
        alt={article.title}
        class="mt-8 aspect-[16/9] w-full rounded-xl object-cover border border-white/5"
        loading="lazy"
      />
    )}

    <div class="mt-10">
      <RichText blocks={blocks} />
    </div>

    <hr class="my-12 border-white/5" />

    <div class="card p-6 text-center">
      <p class="text-xs uppercase tracking-[0.18em] text-neon-green/90">Ready to try it?</p>
      <h2 class="mt-2 text-2xl font-semibold text-white">Get a free test pack</h2>
      <p class="mt-1 text-sm text-slate-400">No credit card. Engineer replies within 5 minutes.</p>
      <a class="btn-primary mt-4" href={settings.telegramLink || '#'} target="_blank" rel="noopener">
        Message on Telegram
      </a>
    </div>
  </article>

  <FloatingContactCTA />
</Base>
