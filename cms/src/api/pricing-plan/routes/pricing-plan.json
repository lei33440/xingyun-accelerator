{
  "routes": [
    {
      "method": "GET",
      "path": "/pricing-plans",
      "handler": "pricing-plan.find",
      "config": { "policies": [], "auth": false }
    },
    {
      "method": "GET",
      "path": "/pricing-plans/:id",
