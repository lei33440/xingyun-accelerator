{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "SEO-friendly blog posts shown on the public site."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 320
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "string",
      "default": "Guides"
    },
    "tags": {
      "type": "json"
    },
    "readingMinutes": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 60
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 80
    },
    "seoDescription": {
      "type": "text",
      "maxLength": 200
    },
    "seoKeywords": {
      "type": "string",
      "maxLength": 200
    }
  }
}
