HOST=127.0.0.1
PORT=1337
APP_KEYS=appKey1,appKey2,appKey3,appKey4
API_TOKEN_SALT=pleaseChangeMe_apiTokenSalt
ADMIN_JWT_SECRET=pleaseChangeMe_adminJwt
TRANSFER_TOKEN_SALT=pleaseChangeMe_transferToken
JWT_SECRET=pleaseChangeMe_jwt

# Public read-only API token used by /web at build time.
# Generate one in Strapi admin: Settings -> API Tokens -> Create new (Type: Read-only, Duration: Unlimited)
STRAPI_READ_TOKEN=

# Shared secret for the revalidate webhook. Must match web/REVALIDATE_SECRET.
REVALIDATE_SECRET=pleaseChangeMe_revalidateSecret

# Comma-separated list of public origins allowed to call the read API (CORS).
# Include both your public site and your CMS admin domain.
WEB_ORIGIN=https://example.com
